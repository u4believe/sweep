# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
DEV_JWT_SECRET=
PASSPORT_SECRET=
DEVELOPER_JWT_SECRET=
SESSION_SECRET=
ADMIN_SECRET=

# ─── Circle ───────────────────────────────────────────────────────────────────
CIRCLE_API_BASE_URL=https://api.circle.com/v1/w3s
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_WALLET_SET_ID=
CIRCLE_GAS_STATION_ENABLED=true
CIRCLE_ARC_TESTNET_USDC_TOKEN_ID=
CIRCLE_PLATFORM_WALLET_ADDRESS=
CIRCLE_PLATFORM_WALLET_ID=
CIRCLE_PLATFORM_WALLET_ID_ARC_TESTNET=
CIRCLE_PLATFORM_WALLET_ID_BASE_SEPOLIA=
CIRCLE_WEBHOOK_SECRET=

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=
BASE_USDC_ADDRESS=
ARC_RPC_URL=
ARC_USDC_ADDRESS=
ESCROW_CONTRACT_ADDRESS=

# ─── Email (Resend — https://resend.com) ──────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="App Name <no-reply@yourdomain.com>"

# ─── Legacy SMTP (unused if RESEND_API_KEY is set) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=