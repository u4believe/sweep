# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Public URL of this deployment — used to build email verification links
APP_URL=https://your-app.up.railway.app

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
DEV_JWT_SECRET=
PASSPORT_SECRET=
DEVELOPER_JWT_SECRET=
SESSION_SECRET=
ADMIN_SECRET=

# ─── Circle ───────────────────────────────────────────────────────────────────
# Base URL only — no /v1/w3s suffix. The code appends paths itself.
# Sandbox: https://api-sandbox.circle.com  |  Production: https://api.circle.com
CIRCLE_API_BASE_URL=https://api-sandbox.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_WALLET_SET_ID=
CIRCLE_GAS_STATION_ENABLED=true
CIRCLE_ARC_TESTNET_USDC_TOKEN_ID=
CIRCLE_PLATFORM_WALLET_ADDRESS=
CIRCLE_PLATFORM_WALLET_ID=
# Per-chain treasury wallet IDs — one Circle wallet object per chain, same on-chain address.
# Run: circle wallets list --walletSetId <your-set-id> to find each chain's wallet ID.
CIRCLE_PLATFORM_WALLET_ID_ARC_TESTNET=
CIRCLE_PLATFORM_WALLET_ID_BASE_SEPOLIA=
CIRCLE_PLATFORM_WALLET_ID_ARB_SEPOLIA=
CIRCLE_PLATFORM_WALLET_ID_OP_SEPOLIA=
CIRCLE_PLATFORM_WALLET_ID_MATIC_AMOY=
CIRCLE_PLATFORM_WALLET_ID_AVAX_FUJI=
# Alternative: set all at once as a JSON map { "ARC-TESTNET": "id1", "BASE-SEPOLIA": "id2", ... }
CIRCLE_PLATFORM_WALLET_IDS_JSON=
CIRCLE_WEBHOOK_SECRET=

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=
BASE_USDC_ADDRESS=
ARC_RPC_URL=
ARC_USDC_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
# Numeric chain IDs — required for EIP-712 burn intent signing during Gateway withdrawals.
# ARC: find at https://testnet.arcscan.app → any tx → "Chain ID" in network info.
ARC_TESTNET_CHAIN_ID=

# ─── Email (Resend — https://resend.com) ──────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM="App Name <no-reply@yourdomain.com>"

# ─── Legacy SMTP (unused if RESEND_API_KEY is set) ────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=